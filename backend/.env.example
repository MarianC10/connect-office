DATABASE_URL=postgres://connectoffice:connectoffice@localhost:5432/connect_office?sslmode=disable
RUN_MIGRATIONS_ON_STARTUP=true

# Base URL for static location images (nginx on :8082). Used by `go run ./cmd/seed`.
# Set to your LAN IP when testing on a physical device, e.g. http://192.168.0.144:8082
STATIC_FILES_BASE_URL=http://localhost:8082

# Seed owner for test locations (`go run ./cmd/seed`). Omit both to use the built-in seed-owner bot.
# SEED_OWNER_USER_ID must match the Supabase Auth user UUID when the account is not in Postgres yet.
# If you have logged into the app once, only SEED_OWNER_EMAIL may be enough (ID is looked up by email).
# SEED_OWNER_EMAIL=you@example.com
# SEED_OWNER_USER_ID=00000000-0000-4000-8000-000000000000
# SEED_OWNER_DISPLAY_NAME=Optional display name

# Supabase Auth (JWT verification for /me).
# HS256: set JWT Secret (Dashboard → Project Settings → API). Optionally set SUPABASE_URL or SUPABASE_JWT_ISSUER to validate iss.
# RS256: leave SUPABASE_JWT_SECRET empty and set SUPABASE_URL or SUPABASE_JWT_ISSUER (JWKS fetched at <issuer>/.well-known/jwks.json).
SUPABASE_JWT_SECRET=

# Issuer claim (iss). Set either SUPABASE_JWT_ISSUER or SUPABASE_URL (https://<ref>.supabase.co).
# SUPABASE_JWT_ISSUER=https://YOUR_PROJECT_REF.supabase.co/auth/v1
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Optional override; default audience checked is "authenticated".
# SUPABASE_JWT_AUDIENCE=authenticated

# Subscriptions (Stripe Checkout). Set SUBSCRIPTIONS_ENABLED=true and STRIPE_SECRET_KEY.
# Stripe Price IDs are seeded in subscription_plans via `go run ./cmd/seed`.
# For local webhooks: stripe listen --forward-to localhost:8080/subscriptions/webhook
SUBSCRIPTIONS_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SUBSCRIPTIONS_CHECKOUT_SUCCESS_URL=coworkingapp://profile/subscription?checkout=success
SUBSCRIPTIONS_CHECKOUT_CANCEL_URL=coworkingapp://profile/subscription?checkout=cancel

# Social features (profiles, friends, visible bookings). Default on when unset.
# SOCIAL_ENABLED=false

# Directory where user avatar uploads are written (served by nginx static-files on :8082).
# AVATAR_UPLOAD_DIR=static/avatars

# Social CLI (`go run ./cmd/social-cli`) — mints JWT with SUPABASE_JWT_SECRET for the DB-only seed bot.
# The seed user is not in Supabase Auth; the CLI never signs in via Supabase.
# SOCIAL_CLI_API_BASE_URL=http://localhost:8080
# SOCIAL_CLI_TOKEN=
