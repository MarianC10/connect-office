DATABASE_URL=postgres://connectoffice:connectoffice@localhost:5432/connect_office?sslmode=disable
RUN_MIGRATIONS_ON_STARTUP=true

# Supabase Auth (JWT verification for /me). JWT secret: Dashboard → Project Settings → API → JWT Secret.
SUPABASE_JWT_SECRET=

# Issuer claim (iss). Set either SUPABASE_JWT_ISSUER or SUPABASE_URL (https://<ref>.supabase.co).
# SUPABASE_JWT_ISSUER=https://YOUR_PROJECT_REF.supabase.co/auth/v1
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Optional override; default audience checked is "authenticated".
# SUPABASE_JWT_AUDIENCE=authenticated
