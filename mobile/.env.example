# Copy to .env and fill in. Expo loads EXPO_PUBLIC_* at build time.

EXPO_PUBLIC_API_BASE_URL=http://192.168.0.144:8080
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Social features (People tab, friends, profile upload). Default on when unset.
EXPO_PUBLIC_SOCIAL_ENABLED=true
